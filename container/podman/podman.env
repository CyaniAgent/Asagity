# Asagity Podman Environment Configuration
# Copy this file to .env in the project root and modify as needed

# PostgreSQL Configuration
POSTGRES_USER=asagity
POSTGRES_PASSWORD=example_password
POSTGRES_DB=asagity_db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PASSWORD=
REDIS_PORT=6379

# Server Configuration
SERVER_PORT=2048
TZ=Asia/Shanghai

# JWT
JWT_SECRET=asagity_secret_miku_39

# Host System Info (passed from host machine)
# Set these in .env before starting containers
HOST_HOSTNAME=
HOST_OS=
HOST_OS_VERSION=
HOST_ARCH=
HOST_CPU=
HOST_MEMORY=
